{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "AuthServiceImpl",
            "request": "launch",
            "mainClass": "com.mall.auth.service.impl.AuthServiceImpl",
            "projectName": "mall-auth"
        },
        {
            "type": "java",
            "name": "UserApplication",
            "request": "launch",
            "mainClass": "UserApplication",
            "projectName": "mall-user"
        },
        {
            "type": "java",
            "name": "Gateway - Local",
            "request": "launch",
            "mainClass": "com.mall.gateway.GatewayApplication",
            "projectName": "mall-gateway",
            "vmArgs": "-Dfile.encoding=UTF-8",
            "args": "--spring.profiles.active=local"
        },
        {
            "type": "java",
            "name": "Gateway - Prod",
            "request": "launch",
            "mainClass": "com.mall.gateway.GatewayApplication",
            "projectName": "mall-gateway",
            "vmArgs": "-Dfile.encoding=UTF-8",
            "args": "--spring.profiles.active=prod"
        },
        {
            "type": "java",
            "name": "AuthApplication",
            "request": "launch",
            "mainClass": "com.mall.auth.AuthApplication",
            "projectName": "mall-auth",
            "vmArgs": "-Dfile.encoding=UTF-8"
        },
        {
            "type": "java",
            "name": "Current File",
            "request": "launch",
            "mainClass": "${file}"
        }
    ]
}