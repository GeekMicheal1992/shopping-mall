<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.mall.auth.mapper.AuthUserMapper">

    <select id="selectByUsername" resultType="com.mall.auth.entity.AuthUser">
        SELECT
            id,
            username,
            password_hash,
            nickname,
            phone,
            email,
            status,
            last_login_at,
            created_at,
            updated_at
        FROM auth_user
        WHERE username = #{username}
        LIMIT 1
    </select>

</mapper>
